# Production terraform.tfvars example
# Copy to terraform.tfvars and fill in sensitive values

project    = "myproject"
aws_region = "us-east-1"

# Networking
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.20.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]

# Compute
instance_type     = "t3.medium"
app_port          = 8080
health_check_path = "/health"

# Database
rds_instance_class = "db.t3.medium"
database_name      = "appdb"
database_username  = "dbadmin"
# database_password = "CHANGE_ME"  # Set via TF_VAR_database_password env var

# TLS
# certificate_arn = "arn:aws:acm:us-east-1:123456789:certificate/xxx"

# Monitoring
# alert_email = "devops@example.com"
